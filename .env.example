# Runtime: Supabase **pooler** (transaction mode) — host often like aws-0-...pooler.supabase.com port 6543
# Must include SSL, e.g. ?sslmode=require (Supabase dashboard “Transaction pooler”)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require"

# Prisma migrate / db push: **Session** or **direct** connection on port 5432 — NOT the transaction pooler URL.
# Copy from Supabase → Project Settings → Database → “Session mode” or “Direct connection”.
# Use ?sslmode=require. If the password has special characters, use the URI the dashboard generates (already encoded).
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

# Better Auth — use a long random secret in production (`openssl rand -base64 32`)
BETTER_AUTH_SECRET=""
# Public URL of the app (origin), e.g. http://localhost:3000
BETTER_AUTH_URL="http://localhost:3000"

# Same-origin API calls from the browser (optional; defaults to localhost in dev)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google Sign-In — optional; enable “Continue with Google” on login/signup
# Redirect URI in GCP: {BETTER_AUTH_URL}/api/auth/callback/google
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Resend — transactional email (verification + password reset). Optional.
# https://resend.com — verify a domain or use onboarding@resend.dev for tests.
# RESEND_API_KEY=""
# EMAIL_FROM="Templaite <onboarding@resend.dev>"
# Allow POST /api/test/resend outside NODE_ENV=development (playground “test email”)
# ALLOW_TEST_EMAIL="true"

# Polar — optional; if unset, the Polar plugin is not loaded
# POLAR_ACCESS_TOKEN=""
# POLAR_SERVER="production"
# POLAR_WEBHOOK_SECRET=""
# Optional checkout product (both required to enable checkout plugin)
# POLAR_CHECKOUT_PRODUCT_ID=""
# POLAR_CHECKOUT_SLUG=""

# AI chat — use Vercel AI Gateway (recommended on Vercel) and/or OpenAI directly
# See https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=""
# Optional gateway model id (default: openai/gpt-4o-mini)
# AI_GATEWAY_MODEL="openai/gpt-4o-mini"

# Direct OpenAI (used only if AI_GATEWAY_API_KEY is unset)
OPENAI_API_KEY=""
# OPENAI_CHAT_MODEL="gpt-4o-mini"
